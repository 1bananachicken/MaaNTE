{
    "interface_version": 2,
    "name": "MaaNTE",
    "description": "异环小助手，由MAAFramework强力驱动！",
    "contact": "QQ群: 1103323319",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaNTE!",
    "github": "https://github.com/1bananachicken/MaaNTE",
    "version": "0.0.1",
    "mirrorchyan_rid": "MaaNTE",
    "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "PrintWindow",
                "mouse": "Seize",
                "keyboard": "PostMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "钓鱼任务",
            "entry": "FishEntrance",
            "option": [
                "钓鱼循环次数",
                "钓鱼数量",
                "自动卖鱼",
                "自动买鱼饵",
                "鱼饵识别阈值"
            ]
        },
        {
            "name": "领取一咖舍收益",
            "entry": "领取一咖舍收益"
        },
        {
            "name": "自动做咖啡",
            "entry": "AutoMakeCoffee",
            "option": [
                "循环次数"
            ]
        },
        {
            "name": "实时辅助",
            "entry": "RealTimeTaskMain",
            "option": [
                "RealTimeCheckInterval",
                "RealTimeAutoSkip",
                "RealTimeAutoTeleport"
            ]
        },
        {
            "name": "自动演奏",
            "entry": "RhythmEntrance",
            "option": [
                "自动选曲",
                "自动连打",
                "目标帧率"
            ]
        }
    ],
    "option": {
        "钓鱼循环次数": {
            "type": "input",
            "label": "最大循环次数",
            "description": "限制整个钓鱼循环最多执行多少次",
            "inputs": [
                {
                    "name": "max_hit",
                    "label": "循环次数",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishStart": {
                    "max_hit": "{max_hit}"
                }
            }
        },
        "钓鱼数量": {
            "type": "input",
            "label": "每次钓鱼数量",
            "description": "设置每次自动钓鱼的数量，建议小于等于99",
            "inputs": [
                {
                    "name": "count",
                    "label": "数量",
                    "default": "99",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishGameStart": {
                    "custom_action_param": {
                        "count": "{count}"
                    }
                }
            }
        },
        "自动卖鱼": {
            "type": "switch",
            "label": "自动卖鱼",
            "description": "是否启用自动卖鱼功能",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "FishStart": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "自动买鱼饵": {
            "type": "switch",
            "label": "自动买鱼饵",
            "description": "是否启用自动买鱼饵功能",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "鱼饵识别阈值": {
            "type": "select",
            "label": "鱼饵识别阈值",
            "description": "如果无法识别点击鱼饵位置，请调低该数值",
            "cases": [
                {
                    "name": "0.8",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.8
                            }
                        }
                    }
                },
                {
                    "name": "0.7",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.7
                            }
                        }
                    }
                },
                {
                    "name": "0.6",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.6
                            }
                        }
                    }
                }
            ]
        },
        "循环次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "循环次数",
                    "default": "10",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "AutoMakeCoffee": {
                    "custom_action_param": {
                        "count": "{循环次数}"
                    }
                }
            }
        },
        "RealTimeCheckInterval": {
            "type": "input",
            "label": "检测间隔 (ms)",
            "description": "两次检测之间的间隔，单位毫秒",
            "inputs": [
                {
                    "name": "interval",
                    "default": "500",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RealTimeSleep": {
                    "post_delay": "{interval}"
                }
            }
        },
        "RealTimeAutoSkip": {
            "type": "switch",
            "label": "自动剧情",
            "description": "是否自动跳过剧情",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "option": [
                        "RealTimeAutoSkipAll"
                    ]
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "RealTimeSkipPlot": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoSkipAll": {
            "type": "switch",
            "label": "自动跳过全部剧情",
            "description": "检测到跳过按钮时自动点击",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeSkipPlot": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeSkipPlot": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleport": {
            "type": "switch",
            "label": "自动传送",
            "description": "检测到特定传送点时自动点击传送",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "option": [
                        "RealTimeAutoTeleportWitte",
                        "RealTimeAutoTeleportPhone"
                    ]
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "RealTimeAutoTeleportWitte": {
            "type": "switch",
            "label": "维特海默塔",
            "description": "是否检测维特海默塔的传送点",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleportPhone": {
            "type": "switch",
            "label": "ReroRero电话亭",
            "description": "是否检测ReroRero电话亭的传送点",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "自动选曲": {
            "type": "switch",
            "label": "自动选曲",
            "description": "启用后自动选择歌曲（迷星叫），关闭则手动指定目标歌曲",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "RhythmSetSong": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "auto_select": true,
                                "song_name": ""
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "option": [
                        "演奏目标歌曲选择"
                    ]
                }
            ],
            "default_case": "No"
        },
        "演奏目标歌曲选择": {
            "type": "select",
            "label": "目标歌曲",
            "description": "选择要演奏的歌曲",
            "cases": [
                {
                    "name": "Heroic_Appearance",
                    "label": "Heroic_Appearance",
                    "pipeline_override": {
                        "RhythmSetSong": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "song_name": "Heroic_Appearance"
                            }
                        }
                    }
                },
                {
                    "name": "Destiny",
                    "label": "Destiny",
                    "pipeline_override": {
                        "RhythmSetSong": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "song_name": "Destiny"
                            }
                        }
                    }
                },
                {
                    "name": "Everlasting_Dazing_Summer_Short",
                    "label": "Everlasting_Dazing_Summer(Short_Ver.)",
                    "pipeline_override": {
                        "RhythmSetSong": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "song_name": "Everlasting_Dazing_Summer(Short_Ver.)"
                            }
                        }
                    }
                },
                {
                    "name": "Everlasting_Dazing_Summer",
                    "label": "Everlasting_Dazing_Summer",
                    "pipeline_override": {
                        "RhythmSetSong": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "song_name": "Everlasting_Dazing_Summer"
                            }
                        }
                    }
                },
                {
                    "name": "迷星叫",
                    "label": "迷星叫",
                    "pipeline_override": {
                        "RhythmSetSong": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "song_name": "迷星叫"
                            }
                        }
                    }
                }
            ],
            "default_case": "Heroic_Appearance"
        },
        "自动连打": {
            "type": "switch",
            "label": "自动连打",
            "description": "启用后连续演奏指定次数，关闭则仅演奏一次",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "option": [
                        "连打模式"
                    ]
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "RhythmSetRepeat": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "auto_repeat_count": 0
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "连打模式": {
            "type": "switch",
            "label": "连打直到活力耗尽",
            "description": "开启后自动连打直到活力耗尽，关闭则使用固定次数",
            "cases": [
                {
                    "name": "Yes",
                    "label": "Max",
                    "pipeline_override": {
                        "RhythmSetRepeat": {
                            "action": "Custom",
                            "custom_action": "rhythm_set_param",
                            "custom_action_param": {
                                "auto_repeat_max": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "固定次数",
                    "option": [
                        "连打次数"
                    ]
                }
            ],
            "default_case": "No"
        },
        "连打次数": {
            "type": "input",
            "label": "连打次数",
            "description": "连续演奏的次数",
            "inputs": [
                {
                    "name": "auto_repeat_count",
                    "label": "次数",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RhythmSetRepeat": {
                    "action": "Custom",
                    "custom_action": "rhythm_set_param",
                    "custom_action_param": {
                        "auto_repeat_count": "{auto_repeat_count}"
                    }
                }
            }
        },
        "目标帧率": {
            "type": "input",
            "label": "目标帧率",
            "description": "演奏循环的每秒帧率，建议30~120",
            "inputs": [
                {
                    "name": "target_fps",
                    "label": "FPS",
                    "default": "60",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RhythmSetFPS": {
                    "action": "Custom",
                    "custom_action": "rhythm_set_param",
                    "custom_action_param": {
                        "target_fps": "{target_fps}"
                    }
                }
            }
        }
    }
}