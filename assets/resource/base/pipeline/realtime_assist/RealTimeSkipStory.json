{
    "RealTimeSkipStory": {
        "desc": "跳过剧情",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "realtime_assist/skip_story_btn.png",
                    "realtime_assist/skip_story_btn_hover.png"
                ],
                "roi": [
                    1210,
                    20,
                    50,
                    50
                ],
                "threshold": 0.7
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 0,
        "next": [
            "RealTimeSkipStoryDialog",
            "RealTimeSkipStorySummary",
            "RealTimeFakeTrue"
        ]
    },
    "RealTimeSkipStoryDialog": {
        "desc": "跳过剧情对话框",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "是否跳过剧情",
                    "是否跳過劇情",
                    "Skip story",
                    "ストーリーをスキップしますか",
                    "스토리를 스킵하시겠습니까"
                ],
                "roi": [
                    420,
                    275,
                    450,
                    50
                ],
                "threshold": 0.8
            }
        },
        "action": "DoNothing",
        "post_delay": 0,
        "next": [
            "RealTimeSkipStoryDialogCheckbox"
        ],
        "on_error": [
            "RealTimeFakeTrue"
        ]
    },
    "RealTimeSkipStoryDialogCheckbox": {
        "desc": "跳过今日剧情复选框",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "realtime_assist/skip_story_dialog_checkbox.png",
                "roi": [
                    550,
                    350,
                    50,
                    50
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "LongPress",
            "param": {
                "duration": 500
            }
        },
        "pre_delay": 500,
        "post_delay": 200,
        "next": [
            "RealTimeSkipStoryDialogConfirm"
        ]
    },
    "RealTimeSkipStoryDialogConfirm": {
        "desc": "确认跳过剧情对话框确认按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "确认记录",
                    "確認記錄",
                    "(?i)Confirm",
                    "記録更新",
                    "确认",
                    "確認",
                    "確定",
                    "确定",
                    "OK",
                    "CONFIRN",
                    "확인"
                ],
                "roi": [
                    700,
                    410,
                    250,
                    70
                ],
                "threshold": 0.8,
                "roi_offset": [
                    0,
                    0,
                    36,
                    0
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 300,
        "next": [
            "RealTimeFakeTrue"
        ]
    },
