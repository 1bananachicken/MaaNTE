{
    "BondGiftEntrance": {
        "desc": "羁绊送礼入口",
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "DoNothing"
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "focus": {
            "Node.Action.Starting": "羁绊送礼: 开始"
        },
        "next": [
            "BondGiftClickJiyu",
            "[JumpBack]SceneAnyEnterEscMenu"
        ]
    },
    "BondGiftClickJiyu": {
        "desc": "识别羁遇按钮并长按进入界面",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "BondGift/jiyu.png",
                "threshold": 0.65,
                "order_by": "Score",
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ]
            }
        },
        "action": {
            "type": "LongPress",
            "param": {
                "duration": 100
            }
        },
        "pre_delay": 200,
        "post_delay": 1500,
        "rate_limit": 0,
        // "focus": {
        //     "Node.Recognition.Succeeded": "羁绊送礼: 找到羁遇按钮 ✓",
        //     "Node.Recognition.Failed": "羁绊送礼: 未找到羁遇按钮 ✗"
        // },
        "next": [
            "BondGiftClickZengli",
            "BondGiftAction"
        ]
    },
    "BondGiftClickZengli": {
        "desc": "识别赠礼按钮并点击（识别不到则认为已点开）",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "BondGift/zengli.png",
                "threshold": 0.7,
                "order_by": "Score"
            }
        },
        "action": {
            "type": "Click"
        },
        "pre_wait_freezes": {
            "time": 500,
            "timeout": 2000
        },
        "pre_delay": 0,
        "post_delay": 200,
        "rate_limit": 0,
        // "focus": {
        //     "Node.Recognition.Succeeded": "羁绊送礼: 找到赠礼按钮 ✓",
        //     "Node.Recognition.Failed": "羁绊送礼: 未找到赠礼按钮（可能已展开）"
        // },
        "next": [
            "BondGiftAction"
        ]
    },
    "BondGiftClickGive": {
        "desc": "点击赠送按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "BondGift/btn_send.png",
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "threshold": 0.7,
                "order_by": "Score"
            }
        },
        "action": {
            "type": "Click"
        },
        "pre_delay": 500,
        "post_delay": 0,
        "rate_limit": 0
        // "focus": {
        //     "Node.Recognition.Succeeded": "点击赠送按钮: 找到赠礼按钮 ✓",
        //     "Node.Recognition.Failed": "点击赠送按钮: 未找到赠礼按钮（可能已展开）"
        // },
    },
    "BondGiftAction": {
        "desc": "羁绊送礼 — Python 负责找角色、送礼",
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "auto_bonding_gift"
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        // "focus": {
        //     "Node.Action.Starting": "羁绊送礼: Python 开始执行"
        // }
    }
}
