    "RealTimeConfirmTeleportPhone": {
        "desc": "确认传送至电话亭",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "realtime_assist/teleport_btn_phone.png",
                "roi": [930, 610, 350, 60],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "LongPress",
            "param": {
                "duration": 100
            }
        },
        "post_delay": 0,
        "next": ["RealTimeSleep"]
    },
    "RealTimeSleep": {
        "desc": "延迟",
        "recognition": "DirectHit",
        "action": "DoNothing",
        "post_delay": 500,
        "next": ["RealTimeTaskMain"]
    }
}