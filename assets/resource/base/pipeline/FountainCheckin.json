{
    "FountainCheckinEntrance": {
        "desc": "喷泉打卡入口",
        "next": [
            "FountainCheckTeleportRequired",
            "FountainRouteNavigation"
        ]
    },
    // 先按世界坐标判断距离；距离远时会在 CustomAction 内完成地图传送，距离近则直接继续。
    "FountainCheckTeleportRequired": {
        "desc": "确认是否需要先使用地图传送到喷泉附近",
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "check_teleport_required",
                "custom_action_param": {
                    "point_id": "fountain",
                    "teleport_point_id": "fountain",
                    "position_backend": "auto",
                    "coordinate_type": "world",
                    "coordinate_timeout": 1.5,
                    "debug": true
                }
            }
        },
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "FountainRouteNavigation"
        ],
        "on_error": [
            "FountainCheckinNotFound"
        ]
    },
    // 从喷泉传送点沿 penquan 路线走到喷泉，再进入原有打卡识别流程。
    "FountainRouteNavigation": {
        "desc": "使用本地路线寻路从喷泉传送点移动到喷泉",
        "action": "Custom",
        "custom_action": "local_route_navigation",
        "custom_action_param": {
            "json_path": "penquan",
            "route_name": "penquan",
            "segment_index": 1,
            "frame_interval": 0.1,
            "tolerance": 5,
            "angle_backend": "auto",
            "position_backend": "auto",
            "debug": false
        },
        "next": [
            "FountainFindButton",
            "FountainCheckinNotFound"
        ]
        // "on_error": [
        //     "FountainCheckinNotFound"
        // ]
    },
    "FountainFindButton": {
        "desc": "识别喷泉打卡按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    765,
                    373,
                    210,
                    40
                ],
                "expected": [
                    "纳库佩达之池",
                    "納庫佩達之池",
                    "(?i)Nacupeda\\s*'\\s*s\\s*Pool",
                    "ナクペイダの池",
                    "나쿠펜다의 연못"
                ]
            }
        },
        "action": "ClickKey",
        "key": 70,
        "post_delay": 500,
        "next": [
            "FountainWaitAnimation"
        ]
    },
    "FountainWaitAnimation": {
        "desc": "等待动画结束，轮询许愿选项",
        "next": [
            "FountainMakeWish",
            "FountainSkipStory",
            "FountainSkipStoryDialog",
            "FountainCheckinIfExit"
        ],
        "timeout": 5000
    },
    "FountainMakeWish": {
        "desc": "识别许愿选项并按F",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    871,
                    415,
                    239,
                    49
                ],
                "expected": [
                    "虔诚许愿",
                    "虔誠許願",
                    "(?i)Make\\s*a\\s*Sincere\\s*Wish",
                    "敬虔な願い",
                    "간절히 소원 빌기"
                ]
            }
        },
        "action": "Click",
        "post_delay": 2000,
        "next": [
            "FountainCheckinAnyExit",
            "FountainSkipStoryDialog",
            "FountainSkipStoryDialogConfirm",
            "FountainCheckinIfExit"
        ]
    },
    "FountainSkipStory": {
        "desc": "长时间未识别到许愿选项，尝试跳过剧情",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1218,
                    24,
                    39,
                    37
                ],
                "template": [
                    "realtime_assist/skip_story_btn.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 0,
        "next": [
            "FountainCheckinAnyExit",
            "FountainSkipStoryDialog",
            "FountainWaitAnimation"
        ]
    },
    "FountainSkipStoryDialog": {
        "desc": "跳过剧情对话框",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "是否跳过剧情",
                    "是否跳過劇情",
                    "Skip Story",
                    "ストーリーをスキップしますか",
                    "스토리를 스킵하시겠습니까"
                ],
                "roi": [
                    420,
                    275,
                    450,
                    50
                ]
            }
        },
        "action": "DoNothing",
        "post_delay": 0,
        "next": [
            "FountainSkipStoryDialogConfirm",
            "FountainWaitAnimation"
        ]
    },
    "FountainSkipStoryDialogConfirm": {
        "desc": "确认跳过剧情对话框确认按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "确认记录",
                    "確認記錄",
                    "(?i)Confirm",
                    "記録更新",
                    "确认",
                    "確認",
                    "確定",
                    "确定",
                    "OK",
                    "CONFIRN",
                    "확인"
                ],
                "roi": [
                    700,
                    410,
                    250,
                    70
                ],
                "roi_offset": [
                    0,
                    0,
                    36,
                    0
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 300,
        "next": [
            "FountainCheckinIfExit",
            "FountainWaitAnimation"
        ]
    },
    "FountainCheckinAnyExit": {
        "desc": "Esc退出",
        "pre_delay": 0,
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27 // ESC
            }
        },
        "post_wait_freezes": {
            "target": [
                0,
                0,
                100,
                100
            ],
            "time": 600
        },
        "post_delay": 0,
        "next": [
            "FountainCheckinIfExit"
        ]
    },
    "FountainCheckinIfExit": {
        "desc": "识别喷泉打卡按钮，判断是否已退出",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    765,
                    373,
                    210,
                    40
                ],
                "expected": [
                    "纳库佩达之池",
                    "納庫佩達之池",
                    "(?i)Nacupeda\\s*'\\s*s\\s*Pool",
                    "ナクペイダの池",
                    "나쿠펜다의 연못"
                ]
            }
        },
        "next": [
            "FountainCheckinExit"
        ]
    },
    "FountainCheckinNotFound": {
        "desc": "未识别到喷泉打卡标识",
        "next": [
            "FountainCheckinExit"
        ],
        "focus": {
            "Node.Action.Succeeded": "❌ 未能找到喷泉打卡图标，请移动到喷泉位置再次进行该任务"
        }
    },
    "FountainCheckinExit": {
        "desc": "喷泉打卡任务出口"
    }
}
