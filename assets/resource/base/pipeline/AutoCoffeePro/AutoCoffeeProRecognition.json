{
    "AutoCoffeeProFindLevel": {
        "desc": "模板匹配目标关卡入口",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": "auto_coffee_pro/level_target.png",
                "threshold": 0.8
            }
        }
    },
    "AutoCoffeeProCheckStart": {
        "desc": "OCR识别开始营业按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1057,
                    648,
                    178,
                    44
                ],
                "expected": [
                    "开始营业",
                    "開始營業",
                    "(?i)Open\\s*Shop",
                    "営業開始",
                    "영업 개시"
                ],
                "threshold": 0.8
            }
        }
    },
    "AutoCoffeeProCheckExit": {
        "desc": "模板匹配退出按钮",
