{
    "FishEntrance": {
        "desc": "钓鱼功能入口",
        "anchor": "FishRestart",
        "next": [
            "FishStart",
            "[JumpBack]FishScenePrepareToFishGame",
            "[JumpBack]FishSceneWorldToPrepare",
            "[JumpBack]__ScenePrivateAnyEnterWorldSuccess"
        ]
    },
    "FishStart": {
        "desc": "钓鱼功能主流程",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "FishSceneOnFishGame"
                ]
            }
        },
        "next": [
            "FishGameStart",
            "FishTaskExit"
        ]
    },
    "FishGameStart": {
        "desc": "正在钓鱼游戏界面，执行钓鱼逻辑",
        "max_hit": 9999,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "FishSceneOnFishGame"
                ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "auto_fish"
            }
        },
        "focus": {
            "Node.Action.Succeeded": "开始钓鱼",
            "Node.Recognition.Failed": "判断不在钓鱼界面，尝试返回"
        },
        "on_error": [
            "[Anchor]FishRestart"
        ],
        "next": [
            "FishGameStart",
            "FishBaitLack"
        ]
    },
    "FishTaskExit": {
        "desc": "钓鱼任务完成"
    },
    "FishBaitLack": {
        "desc": "缺少鱼饵",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    520,
                    340,
                    240,
                    40
                ],
                "expected": "需要装备鱼饵",
                "threshold": 0.8
            }
        },
        "action": {
            "type": "ClickKey",
            "param":{
                "key": [69]
            }
        },
        "focus": {
            "Node.Action.Succeeded": "未装备鱼饵，尝试前往装备"
        },
        "next": [
            "FishClickBaitChoose"
        ]
    },
    "FishClickBaitChoose": {
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "FishSceneOnFishGame"
                ]
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": [
                    69
                ]
            }
        },
        "anchor": "FishRechooseBait",
        "next": [
            "FishChooseGeneralBait",
            "[JumpBack]FishSwipeMouse"
        ]
    },
    "FishChooseGeneralBait": {
        "desc": "找到并选中通用鱼饵",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    389,
                    293,
                    494,
                    135
                ],
                "template": "Fish/FishGeneralBait.png",
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click"
        },
        "focus": {
            "Node.Action.Succeeded": "选择通用鱼饵"
        },
        "next": [
            "FishGotoBuyBait",
            "FishUseBait"
        ]
    },
    "FishSwipeMouse": {
        "desc": "滑动鱼饵界面",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    559,
                    217,
                    167,
                    59
                ],
                "expected": ["更换鱼饵"],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Swipe",
            "param":{
                "begin": [750,350,10,20],
                "end": [530,350,10,20],
                "end_hold": 600
            }
        }
    },
    "FishGotoBuyBait": {
        "desc": "点击购买按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    663,
                    449,
                    237,
                    44
                ],
                "expected": [
                    "购买"
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "FishBaitMax"
        ]
    },
    "FishUseBait": {
        "desc": "点击更换按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    663,
                    449,
                    237,
                    44
                ],
                "expected": [
                    "更换"
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[Anchor]FishRestart"
        ]
    },
    "FishBaitMax": {
        "desc": "选择最多按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1200,
                    617,
                    36,
                    36
                ],
                "template": "Fish/FishBaitMax.png",
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "FishBuyBait"
        ]
    },
    "FishBuyBait": {
        "desc": "点击购买按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    899,
                    663,
                    351,
                    45
                ],
                "expected": [
                    "购买"
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "FishConfirmBuyBait",
            "FishSellFishStart"
        ]
    },
    "FishConfirmBuyBait": {
        "desc":"点击空白区域关闭",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    553,
                    619,
                    175,
                    38
                ],
                "expected": [
                    "点击空白区域关闭"
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": [
                    27 // Esc
                ]
            }
        },
        "next": [
            "FishExitStore"
        ]
    },
    "FishExitStore": {
        "desc": "退出渔具商店",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    10,
                    13,
                    198,
                    57
                ],
                "expected": [
                    "渔具商店"
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": [
                    27
                ]
            }
        },
        "next": [
            "[Anchor]FishRechooseBait"
        ]
    },
    "FishSellFishStart": {
        "desc": "识别到鱼鳞币不足，开始，开始前往卖鱼流程"
    }
}