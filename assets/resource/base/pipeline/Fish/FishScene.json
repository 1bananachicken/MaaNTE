{
    "FishSceneAnyEnterFishGame":{
        "next": [
            "FishScenePrepareToFishGame",
            "[JumpBack]FishSceneWorldToPrepare",
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "FishSceneWorldToPrepare": {
        "desc": "从大世界进入钓鱼准备界面",
        "recognition":  "And",
        "all_of": [
            "FishSceneInWorldNextToFish"
        ],
        "post_delay": 2000,
        "action": {
            "type": "ClickKey",
            "param": {
                "key": [
                    70
                ]
            }
        }
    },
    "FishScenePrepareToFishGame":{
        "desc": "从钓鱼准备界面进入钓鱼游戏界面",
        "recognition":  "And",
        "all_of": [
            "FishSceneOnFishPrepare"
        ],
        "post_delay": 2000,
        "action": {
            "type": "LongPress",
            "param": {
                "target": [
                    1038,
                    616,
                    78,
                    23
                ],
                "duration": 2
            }
        },
        "next": [
            "MouseMoveReset"
        ]
    },
    "FishSceneOnFishGame":{
        "desc": "判断正在钓鱼游戏界面，继续业务流程",
        "recognition": {
            "type": "And",
            "param":{
                "all_of": [
                    "FishSceneBaitButton",
                    "FishSceneHookButton"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "FishSceneOnFishGameCasting":{
        "desc": "判断正在等待上鱼/钓上大鱼动画中，继续业务流程",
        "recognition": {
            "type": "And",
            "param":{
                "all_of": [
                    "FishSceneHookButton"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "FishSceneOnFishPrepare": {
        "desc": "判断正在钓鱼准备界面，继续业务流程",
        "recognition":{
            "type": "TemplateMatch",
            "param": {
                "roi": [823,43,117,42],
                "template": [
                    "Fish/FishPrepareTitle.png"
                ],
                "threshold": 0.8
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "FishSceneInWorldNextToFish": {
        "desc": "判断正在大世界钓鱼台边，继续业务流程",
        "recognition": "And",
