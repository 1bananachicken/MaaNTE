{
    "task": [
        {
            "name": "ClaimRewards",
            "label": "$task_claim_rewards_name",
            "entry": "ClaimRewardsEntrance",
            "description": "$task_claim_rewards_desc",
            "controller": [
                "Win32",
                "Win32-Front"
            ],
            "option": [
                "ClaimRewardsActivity",
                "ClaimRewardsBattlePass"
            ]
        }
    ],
    "option": {
        "ClaimRewardsActivity": {
            "type": "switch",
            "label": "领取活跃度奖励",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "ClaimRewardsActivity": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "ClaimRewardsActivity": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "ClaimRewardsBattlePass": {
            "type": "switch",
            "label": "领取环期赏令奖励",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "ClaimRewardsBattlePass": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "ClaimRewardsBattlePass": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}
