{
    "task": [
        {
            "name": "BagelSpam",
            "label": "$task_bagel_spam_label",
            "entry": "BagelSpamEntrance",
            "description": "$task_bagel_spam_desc",
            "controller": [
                "Win32-Front"
            ],
            "group": [
                "HethereauHobbies"
            ],
            "option": [
                "BagelSpamText"
            ]
        }
    ],
    "option": {
        "BagelSpamText": {
            "type": "input",
            "label": "$task_bagel_spam_option_text_label",
            "description": "$task_bagel_spam_option_text_desc",
            "inputs": [
                {
                    "name": "title",
                    "label": "$task_bagel_spam_option_text_title_label",
                    "default": "关注伊波恩喵",
                    "pipeline_type": "string"
                },
                {
                    "name": "body",
                    "label": "$task_bagel_spam_option_text_body_label",
                    "default": "关注伊波恩谢谢喵",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "BagelSpamInputTitle": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "titles": "{title}",
                                "bodies": "{body}",
                                "output": "title"
                            }
                        }
                    }
                },
                "BagelSpamInputContent": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "titles": "{title}",
                                "bodies": "{body}",
                                "output": "body"
                            }
                        }
                    }
                }
            }
        }
    }
}
