{
    "task": [
        {
            "name": "PinkPawHeist",
            "label": "粉爪大劫案",
            "entry": "PinkPawHeist_Main",
            "description": "自动刷取粉爪大劫案，需要<span style='color:red'>“桌面端-前台”</span>控制器。",
            "option": [
                "PinkPawHeist_Loop",
                "PinkPawHeist_Scheme"
            ],
            "controller": [
                "Win32-Front"
            ],
            "group": [
                "HethereauHobbies"
            ]
        }
    ],
    "option": {
        "PinkPawHeist_Loop": {
            "type": "switch",
            "label": "无限循环",
            "description": "无限循环，直到手动结束任务。",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启"
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "option": [
                        "PinkPawHeist_LoopCount"
                    ]
                }
            ]
        },
        "PinkPawHeist_LoopCount": {
            "type": "input",
            "label": "循环次数",
            "inputs": [
                {
                    "name": "count",
                    "label": "循环次数",
                    "default": "10",
                    "pipeline_type": "int",
                    "verify": "^[1-9]\\d{0,3}$"
                }
            ],
            "pipeline_override": {
                "PinkPawHeist_CoreSequence": {
                    "max_hit": "{count}"
                }
            }
        },
        "PinkPawHeist_Scheme": {
            "type": "select",
            "label": "地图方案",
            "description": "选择本次战斗的地图移动方案。。",
            "default_case": "Core2",
            "cases": [
                {
                    "name": "Core1",
                    "label": "方案一",
                    "pipeline_override": {
                        "PinkPawHeist_ExecuteScheme": {
                            "next": [
                                "PinkPawHeist_Scheme1"
                            ]
                        }
                    },
                    "option": [
                        "PinkPawHeist_Scheme_Core1_desc"
                    ]
                },
                {
                    "name": "Core2",
                    "label": "方案二",
                    "pipeline_override": {
                        "PinkPawHeist_ExecuteScheme": {
                            "next": [
                                "PinkPawHeist_Scheme2"
                            ]
                        }
                    },
                    "option": [
                        "PinkPawHeist_Scheme_Core2_desc"
                    ]
                },
                {
                    "name": "Core3",
                    "label": "方案三",
                    "pipeline_override": {
                        "PinkPawHeist_ExecuteScheme": {
                            "next": [
                                "PinkPawHeist_Scheme3"
                            ]
                        }
                    },
                    "option": [
                        "PinkPawHeist_Scheme_Core3_AvoidMethod",
                        "PinkPawHeist_Scheme_Core3_TimingScale",
                        "PinkPawHeist_Scheme_Core3_desc"
                    ]
                }
            ]
        },
        "PinkPawHeist_Scheme_Core1_desc": {
            "type": "input",
            "label": "方案一说明",
            "description": "<span style='color:orange'>目前极不稳定。</span><br><span style='color:green'>配队要求：</span>3号位为薄荷。推荐1娜娜莉3薄荷4早雾。<br><span style='color:green'>路线说明：</span>在G层进行搜索，并前往L1-01撤离点撤离。<br><span style='color:orange'>其它要求：</span>关闭游戏的移动镜头修正功能",
            "inputs": []
        },
        "PinkPawHeist_Scheme_Core2_desc": {
            "type": "input",
            "label": "方案二说明",
            "description": "<span style='color:orange'>更稳定收益更高，请设置画质到性能档位，帧率设置120帧，关闭设置里的移动镜头修正！到小吱旁边启动！</span><br><span style='color:green'>配队要求：</span>1娜娜莉2任意位3早雾4狼（没有娜娜莉可换埃德加）<br><span style='color:green'>路线说明：</span>走藏品层路线撤离",
            "inputs": []
        },
        "PinkPawHeist_Scheme_Core3_desc": {
            "type": "input",
            "label": "方案三说明",
            "description": "<span style='color:orange'>移植自 ok-nte 粉爪路径2，请设置画质到性能档位，帧率设置120帧，关闭设置里的移动镜头修正！打开按下锁定镜头回正！到小吱旁边启动！</span><br><span style='color:green'>路线说明：</span>使用 ok 路径2，按固定站位配队；只需要在“方案三配队”里选择你实际使用的站位组合。",
            "inputs": []
        },
        "PinkPawHeist_Scheme_Core3_AvoidMethod": {
            "type": "select",
            "label": "方案三配队",
            "description": "选择你实际使用的固定站位配队；程序会据此切换 ok 路径2的对应分支。",
            "default_case": "Dash",
            "cases": [
                {
                    "name": "Dash",
                    "label": "1早雾 2翳 3薄荷 4任意",
                    "pipeline_override": {
                        "PinkPawHeist_Scheme3": {
                            "next": [
                                "PinkPawHeist_Scheme3_Dash"
                            ]
                        }
                    }
                },
                {
                    "name": "Attack",
                    "label": "1战斗 2浔 3薄荷 4任意",
                    "pipeline_override": {
                        "PinkPawHeist_Scheme3": {
                            "next": [
                                "PinkPawHeist_Scheme3_Attack"
                            ]
                        }
                    }
                }
            ]
        },
        "PinkPawHeist_Scheme_Core3_TimingScale": {
            "type": "input",
            "label": "路线时间微调",
            "description": "默认 1.00。低延迟发键已启用，只有实测路线仍有固定偏差时再微调：走过头调小，没走到调大。锁门等待不会被这个倍率缩短。",
            "inputs": [
                {
                    "name": "timing_scale",
                    "label": "倍率",
                    "default": "1.00",
                    "pipeline_type": "string",
                    "verify": "^0\\.(2[5-9]|[3-9]\\d?)$|^1(\\.0{1,2}|\\.1\\d?|\\.2)?$"
                }
            ],
            "pipeline_override": {
                "PinkPawHeist_Scheme3_Dash": {
                    "custom_action_param": {
                        "avoid_method": "dash",
                        "interaction_pause": 0.2,
                        "timing_scale": "{timing_scale}"
                    }
                },
                "PinkPawHeist_Scheme3_Attack": {
                    "custom_action_param": {
                        "avoid_method": "attack",
                        "interaction_pause": 0.2,
                        "timing_scale": "{timing_scale}"
                    }
                }
            }
        }
    }
}
