{
    "task": [
        {
            "name": "粉爪大劫案",
            "entry": "PinkPawHeist_Main",
            "description": "自动刷取粉爪大劫案，需要<span style='color:red'>“桌面端-前台”</span>控制器。",
            "option": [
                "PinkPawHeist_Scheme",
                "PinkPawHeist_LoopCount"
            ],
            "controller": [
                "Win32-Front"
            ]
        }
    ],
    "option": {
        "PinkPawHeist_LoopCount": {
            "type": "input",
            "label": "循环次数",
            "description": "刷取粉爪大劫案的次数",
            "inputs": [
                {
                    "name": "count",
                    "label": "循环次数",
                    "default": "1",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "PinkPawHeist_CoreSequence": {
                    "max_hit": "{count}"
                }
            }
        },
        "PinkPawHeist_Scheme": {
            "type": "select",
            "label": "地图方案",
            "description": "选择本次战斗的地图移动方案。。",
            "default_case": "Core1",
            "description": "选择本次战斗的地图移动方案。方案1需要配队：1娜娜莉3薄荷4早雾，需要一定练度，目前极不稳定。方案2需要配队：1娜娜莉3早雾4狼，走藏品层路线难撤离更稳定收益更高，请设置画质到性能档位，关闭设置里的移动镜头修正！",
            "default_case": "Core2",
            "cases": [
                {
                    "name": "Core1",
                    "label": "方案一",
                    "pipeline_override": {
                        "PinkPawHeist_ExecuteScheme": {
                            "next": [
                                "PinkPawHeist_Scheme1"
                            ]
                        }
                    },
                    "option": [
                        "PinkPawHeist_Scheme_Core1_desc"
                    ]
                },
                {
                    "name": "Core2",
                    "label": "方案二",
                    "pipeline_override": {
                        "PinkPawHeist_ExecuteScheme": {
                            "next": [
                                "PinkPawHeist_Scheme2_Actions"
                            ]
                        }
                    },
                    "option": [
                        "PinkPawHeist_Scheme_Core2_desc"
                    ]
                }
            ]
        },
        "PinkPawHeist_Scheme_Core1_desc": {
            "type": "input",
            "label": "方案一说明",
            "description": "<span style='color:orange'>目前极不稳定。</span><br><span style='color:green'>配队要求：</span>3号位为薄荷。推荐1娜娜莉3薄荷4早雾。<br><span style='color:green'>路线说明：</span>在G层进行搜索，并前往L1-01撤离点撤离。",
            "inputs": []
        },
        "PinkPawHeist_Scheme_Core2_desc": {
            "type": "input",
            "label": "方案二说明",
            "description": "<span style='color:orange'>暂无作用，仅供测试</span><br><span style='color:green'>配队要求：</span>测试<br><span style='color:green'>路线说明：</span>测试",
            "inputs": []
        }
    }
}
