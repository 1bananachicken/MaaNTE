{
    "task": [
        {
            "name": "OnlineRoute",
            "label": "$task_online_route_label",
            "description": "$task_online_route_desc",
            "entry": "OnlineRoute",
            "option": [
                "OnlineRouteSettings",
                "OnlineRouteAngleBackend",
                "OnlineRouteDebug"
            ],
            "group": [
                "RealTimeAssist"
            ]
        }
    ],
    "option": {
        "OnlineRouteSettings": {
            "type": "input",
            "label": "$task_online_route_option_settings",
            "description": "$task_online_route_option_settings_desc",
            "inputs": [
                {
                    "name": "host",
                    "label": "$task_position_stream_input_host",
                    "default": "0.0.0.0",
                    "pipeline_type": "string",
                    "verify": "^.+$"
                },
                {
                    "name": "port",
                    "label": "$task_position_stream_input_port",
                    "default": "14514",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                },
                {
                    "name": "tolerance",
                    "label": "$task_navi_move_to_input_tolerance",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "OnlineRoute": {
                    "custom_action_param": {
                        "host": "{host}",
                        "port": "{port}",
                        "tolerance": "{tolerance}"
                    }
                }
            }
        },
        "OnlineRouteAngleBackend": {
            "type": "select",
            "label": "$task_position_stream_option_angle_backend",
            "description": "$task_position_stream_option_angle_backend_desc",
            "cases": [
                {
                    "name": "auto",
                    "label": "Auto",
                    "pipeline_override": {
                        "OnlineRouteAngleBackendConfig": {
                            "attach": {
                                "angle_backend": "auto"
                            }
                        }
                    }
                },
                {
                    "name": "directml",
                    "label": "DirectML",
                    "pipeline_override": {
                        "OnlineRouteAngleBackendConfig": {
                            "attach": {
                                "angle_backend": "directml"
                            }
                        }
                    }
                },
                {
                    "name": "cpu",
                    "label": "CPU",
                    "pipeline_override": {
                        "OnlineRouteAngleBackendConfig": {
                            "attach": {
                                "angle_backend": "cpu"
                            }
                        }
                    }
                }
            ],
            "default_case": "auto"
        },
        "OnlineRouteDebug": {
            "type": "switch",
            "label": "$task_position_stream_option_debug",
            "description": "$task_position_stream_option_debug_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "OnlineRouteDebugConfig": {
                            "attach": {
                                "debug": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "OnlineRouteDebugConfig": {
                            "attach": {
                                "debug": false
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        }
    }
}
