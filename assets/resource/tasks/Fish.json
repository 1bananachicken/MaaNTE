{
    "task": [
        {
            "name": "Fish",
            "label": "$task_fish_label",
            "entry": "FishEntrance",
            "option": [
                "FishLoopInfinite",
                "FishNumber",
                "FishSellAuto",
                "FishBuyBaitAuto"
            ],
            "group": ["HethereauHobbies"]
        },
        {
            "name": "FishNew",
            "label": "$task_fish_new_label",
            "entry": "FishNewEntrance",
            "description": "$task_fish_new_desc",
            "option": ["FishSellAuto", "FishBuyBaitAuto"],
            "group": ["HethereauHobbies"]
        },
        {
            "name": "FishFork2",
            "label": "$task_fish_fork_2_label",
            "description": "$task_fish_fork_2_desc",
            "entry": "FishFork2",
            "option": [
                "钓鱼通用设置",
                "溜鱼设置",
                "卖鱼买换饵开关",
                "卖鱼买换饵设置"
            ],
            "group": ["HethereauHobbies"]
        }
    ],
    "option": {
        "FishLoopTime": {
            "type": "input",
            "label": "$task_fish_option_loop_time",
            "description": "$task_fish_option_loop_time_desc",
            "inputs": [
                {
                    "name": "max_hit",
                    "label": "$task_fish_option_loop_time",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishStart": {
                    "max_hit": "{max_hit}"
                }
            }
        },
        "FishNumber": {
            "type": "input",
            "label": "$task_fish_option_count",
            "description": "$task_fish_option_count_desc",
            "inputs": [
                {
                    "name": "count",
                    "label": "$task_fish_option_count_input",
                    "default": "99",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishGameStart": {
                    "custom_action_param": {
                        "count": "{count}"
                    }
                }
            }
        },
        "FishLoopInfinite": {
            "type": "switch",
            "label": "$task_fish_option_infinite",
            "description": "$task_fish_option_infinite_desc",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "FishEntrance": {
                            "next": ["FishLoopStart"]
                        },
                        "FishGameStart": {
                            "next": [
                                "AutoSellFish",
                                "AutoBuyFishBait",
                                "FishLoopStart"
                            ]
                        },
                        "AutoSellFish": {
                            "next": [
                                "AutoBuyFishBait",
                                "FishLoopStart"
                            ]
                        },
                        "AutoBuyFishBait": {
                            "next": ["FishLoopStart"]
                        },
                        "FishBaitHandled": {
                            "next": ["FishLoopStart"]
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "option": ["FishLoopTime"]
                }
            ]
        },
        "FishSellAuto": {
            "type": "switch",
            "label": "$task_fish_option_auto_sell",
            "description": "$task_fish_option_auto_sell_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": true
                        },
                        "FishNewOpenFishMaster": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": false
                        },
                        "FishNewOpenFishMaster": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FishBuyBaitAuto": {
            "type": "switch",
            "label": "$task_fish_option_auto_buy_bait",
            "description": "$task_fish_option_auto_buy_bait_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": true
                        },
                        "FishGotoBuyBait": {
                            "enabled": true
                        },
                        "FishNewGotoBuyBait": {
                            "enabled": true
                        }
                    },
                    "option": ["FishBaitThreshold"]
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": false
                        },
                        "FishGotoBuyBait": {
                            "enabled": false
                        },
                        "FishNewGotoBuyBait": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FishBaitThreshold": {
            "type": "select",
            "label": "$task_fish_option_bait_threshold",
            "description": "$task_fish_option_bait_threshold_desc",
            "cases": [
                {
                    "name": "0.8",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.8
                            }
                        }
                    }
                },
                {
                    "name": "0.7",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.7
                            }
                        }
                    }
                },
                {
                    "name": "0.6",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.6
                            }
                        }
                    }
                },
                {
                    "name": "0.5",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.5
                            }
                        }
                    }
                },
                {
                    "name": "0.4",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.4
                            }
                        }
                    }
                }
            ]
        },
        "钓鱼通用设置": {
            "type": "input",
            "inputs": [
                {
                    "name": "终止时间",
                    "label": "终止时间",
                    "description": "到达时间后终止该节点，支持 ISO 8601 格式。如果时间早于当前时间，自动改为明天的该时间。示例: `2076-05-04T03:02:01` `03:14:25`",
                    "pipeline_type": "string",
                    "default": ""
                }
            ],
            "pipeline_override": {
                "FishFork2": {
                    "attach": {
                        "终止时间": "{终止时间}"
                    }
                }
            }
        },
        "溜鱼设置": {
            "type": "input",
            "inputs": [
                {
                    "name": "溜鱼_midpoint_pix_range",
                    "label": "溜鱼中点停顿范围 (pix)",
                    "pipeline_type": "int",
                    "default": "5"
                },
                {
                    "name": "溜鱼_midpoint_sleep_time",
                    "label": "溜鱼中点停顿时间 (ms)",
                    "pipeline_type": "int",
                    "default": "5"
                }
            ],
            "pipeline_override": {
                "FishFork2": {
                    "attach": {
                        "溜鱼_midpoint_pix_range": "{溜鱼_midpoint_pix_range}",
                        "溜鱼_midpoint_sleep_time": "{溜鱼_midpoint_sleep_time}"
                    }
                }
            }
        },
        "卖鱼买换饵开关": {
            "type": "switch",
            "label": "自动卖鱼买换饵 (抢占鼠标)",
            "description": "无饵或满舱时，按顺序执行 `卖鱼` `买饵` `换饵`。由于涉及点击操作，会抢占鼠标",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "FishFork2": {
                            "attach": {
                                "卖鱼买换饵开关": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "FishFork2": {
                            "attach": {
                                "卖鱼买换饵开关": false
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "卖鱼买换饵设置": {
            "type": "input",
            "inputs": [
                {
                    "name": "买饵次数",
                    "label": "买饵次数",
                    "description": "次数 `n` 代表买 `n * 99` 个饵",
                    "pipeline_type": "int",
                    "default": "4"
                }
            ],
            "pipeline_override": {
                "FishFork2": {
                    "attach": {
                        "买饵次数": "{买饵次数}"
                    }
                }
            }
        }
    }
}
