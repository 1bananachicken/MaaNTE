{
    "task": [
        {
            "name": "PositionStream",
            "label": "$task_position_stream_label",
            "description": "$task_position_stream_desc",
            "entry": "PositionStream",
            "option": [
                "PositionStreamSettings",
                "PositionStreamAngleBackend",
                "PositionStreamDebug"
            ],
            "group": [
                "RealTimeAssist"
            ]
        }
    ],
    "option": {
        "PositionStreamSettings": {
            "type": "input",
            "label": "$task_position_stream_option_settings",
            "description": "$task_position_stream_option_settings_desc",
            "inputs": [
                {
                    "name": "host",
                    "label": "$task_position_stream_input_host",
                    "default": "0.0.0.0",
                    "pipeline_type": "string",
                    "verify": "^.+$"
                },
                {
                    "name": "port",
                    "label": "$task_position_stream_input_port",
                    "default": "14514",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                },
                {
                    "name": "frame_interval",
                    "label": "$task_position_stream_input_frame_interval",
                    "description": "$task_position_stream_input_frame_interval_desc",
                    "default": "0.1",
                    "pipeline_type": "string",
                    "verify": "^\\d+(\\.\\d+)?$"
                }
            ],
            "pipeline_override": {
                "PositionStream": {
                    "custom_action_param": {
                        "host": "{host}",
                        "port": "{port}",
                        "frame_interval": "{frame_interval}"
                    }
                }
            }
        },
        "PositionStreamAngleBackend": {
            "type": "select",
            "label": "$task_position_stream_option_angle_backend",
            "description": "$task_position_stream_option_angle_backend_desc",
            "cases": [
                {
                    "name": "auto",
                    "label": "Auto",
                    "pipeline_override": {
                        "PositionStreamAngleBackendConfig": {
                            "attach": {
                                "angle_backend": "auto"
                            }
                        }
                    }
                },
                {
                    "name": "directml",
                    "label": "DirectML",
                    "pipeline_override": {
                        "PositionStreamAngleBackendConfig": {
                            "attach": {
                                "angle_backend": "directml"
                            }
                        }
                    }
                },
                {
                    "name": "cpu",
                    "label": "CPU",
                    "pipeline_override": {
                        "PositionStreamAngleBackendConfig": {
                            "attach": {
                                "angle_backend": "cpu"
                            }
                        }
                    }
                }
            ],
            "default_case": "auto"
        },
        "PositionStreamDebug": {
            "type": "switch",
            "label": "$task_position_stream_option_debug",
            "description": "$task_position_stream_option_debug_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "PositionStreamDebugConfig": {
                            "attach": {
                                "debug": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "PositionStreamDebugConfig": {
                            "attach": {
                                "debug": false
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        }
    }
}
