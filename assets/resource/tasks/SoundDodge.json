{
    "task": [
        {
            "name": "SoundDodge",
            "label": "$task_sound_dodge_label",
            "entry": "SoundDodgeMain",
            "description": "$task_sound_dodge_desc",
            "option": [
                "SoundDodgeEnable",
                "SoundDodgeAllAttacks",
                "SoundDodgeThreshold",
                "SoundCounterThreshold",
                "SoundMonitorProcessAudioOnly"
            ],
            "controller": [
                "Win32-Front"
            ],
            "group": [
                "RealTimeAssist"
            ]
        }
    ],
    "option": {
        "SoundDodgeEnable": {
            "type": "switch",
            "label": "$task_sound_dodge_option_enable",
            "description": "$task_sound_dodge_option_enable_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {}
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "enable_sound_trigger": false
                            }
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "SoundDodgeAllAttacks": {
            "type": "switch",
            "label": "$task_sound_dodge_option_dodge_only",
            "description": "$task_sound_dodge_option_dodge_only_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$task_sound_dodge_option_dodge_only_case_yes",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "dodge_all_attacks": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$task_sound_dodge_option_dodge_only_case_no",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "dodge_all_attacks": false
                            }
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "SoundDodgeThreshold": {
            "type": "input",
            "label": "$task_sound_dodge_option_dodge_threshold",
            "description": "$task_sound_dodge_option_dodge_threshold_desc",
            "inputs": [
                {
                    "name": "threshold",
                    "default": "0.13",
                    "pipeline_type": "string",
                    "verify": "^0\\.\\d+$|^1\\.0*$"
                }
            ],
            "pipeline_override": {
                "SoundDodgeMain": {
                    "custom_action_param": {
                        "threshold": "{threshold}"
                    }
                }
            }
        },
        "SoundCounterThreshold": {
            "type": "input",
            "label": "$task_sound_dodge_option_counter_threshold",
            "description": "$task_sound_dodge_option_counter_threshold_desc",
            "inputs": [
                {
                    "name": "counter_threshold",
                    "default": "0.12",
                    "pipeline_type": "string",
                    "verify": "^0\\.\\d+$|^1\\.0*$"
                }
            ],
            "pipeline_override": {
                "SoundDodgeMain": {
                    "custom_action_param": {
                        "counter_attack_threshold": "{counter_threshold}"
                    }
                }
            }
        },
        "SoundMonitorProcessAudioOnly": {
            "type": "switch",
            "label": "仅监视进程音频",
            "description": "开启后仅监听 HTGame.exe 的进程音频流，避免其他软件声音干扰",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "monitor_process_audio_only": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "SoundDodgeMain": {
                            "custom_action_param": {
                                "monitor_process_audio_only": false
                            }
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}
