{
  "task": [
    {
      "name": "自动驾驶数据集收集",
      "label": "Dataset Recorder",
      "description": "开始此任务前确保小地图设置好目的地，默认录制时长为60秒，每秒采样2次",
      "entry": "DatasetRecorder",
      "default_check": false,
      "option": [
        "DatasetRecorderSettings"
      ]
    }
  ],
  "option": {
    "DatasetRecorderSettings": {
      "label": "Record settings",
      "type": "input",
      "inputs": [
        {
          "name": "输出目录",
          "label": "Output dir",
          "default": "debug/dataset",
          "pipeline_type": "string",
          "verify": "^.+$"
        },
        {
          "name": "录制时长",
          "label": "Seconds",
          "default": "60",
          "pipeline_type": "int",
          "verify": "^\\d+$",
          "description": "录制时长，默认为60秒"
        },
        {
          "name": "录制延迟",
          "label": "Start delay",
          "default": "1",
          "pipeline_type": "int",
          "verify": "^\\d+$",
        }
      ],
      "pipeline_override": {
        "DatasetRecorder": {
          "custom_action_param": {
            "output_dir": "{OutputDir}",
            "duration_seconds": "{DurationSeconds}",
            "start_delay_seconds": "{StartDelaySeconds}"
          }
        }
      }
    }
  }
}
