{
    "task": [
        {
            "name": "NaviRouteFollow",
            "label": "$task_navi_route_follow_label",
            "description": "$task_navi_route_follow_desc",
            "entry": "NaviRouteFollow",
            "option": [
                "NaviRouteFollowSettings"
            ],
            "group": [
                "RealTimeAssist"
            ]
        }
    ],
    "option": {
        "NaviRouteFollowSettings": {
            "type": "input",
            "label": "$task_navi_route_follow_option_settings",
            "description": "$task_navi_route_follow_option_settings_desc",
            "inputs": [
                {
                    "name": "host",
                    "label": "$task_navi_websocket_input_host",
                    "default": "0.0.0.0",
                    "pipeline_type": "string",
                    "verify": "^.+$"
                },
                {
                    "name": "port",
                    "label": "$task_navi_websocket_input_port",
                    "default": "14514",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                },
                {
                    "name": "tolerance",
                    "label": "$task_navi_move_to_input_tolerance",
                    "default": "80",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                },
                {
                    "name": "angle_backend",
                    "label": "$task_navi_websocket_option_angle_backend",
                    "description": "$task_navi_websocket_option_angle_backend_desc",
                    "default": "auto",
                    "pipeline_type": "string",
                    "verify": "^(auto|directml|cpu)$"
                },
                {
                    "name": "debug",
                    "label": "$task_navi_websocket_option_debug",
                    "description": "$task_navi_websocket_option_debug_desc",
                    "default": "false",
                    "pipeline_type": "bool",
                    "verify": "^(true|false)$"
                }
            ],
            "pipeline_override": {
                "NaviRouteFollow": {
                    "custom_action_param": {
                        "host": "{host}",
                        "port": "{port}",
                        "tolerance": "{tolerance}",
                        "angle_backend": "{angle_backend}",
                        "debug": "{debug}"
                    }
                }
            }
        }
    }
}
