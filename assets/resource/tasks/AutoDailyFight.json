{
    "task": [
        {
            "name": "自动日常本",
            "label": "自动日常本",
            "description": "刷取日常本",
            "entry": "DF_Action",
            "option": [
                "DF_TargetNumber_clean",
                "DF_Action"
            ]
        }
    ],
    "option": {
        "DF_TargetNumber_clean": {
            "type": "input",
            "label": "$刷取次数",
            "description": "$指定日常本的刷取次数",
            "inputs": [
                {
                    "name": "DF_TargetNumber_clean_Value",
                    "label": "$输入次数",
                    "description": "$执行刷取次数后结束",
                    "pipeline_type": "int",
                    "verify": "^(([1-9])|([1-9][0-9]))$",
                    "default": "1"
                }
            ],
            "pipeline_override": {
                "DF_TargetNumber_clean": {
                    "recognition": {
                        "param": {
                            "custom_recognition_param": {
                                "clean_node_name": "DF_TargetNumber",
                                "target_number": "{DF_TargetNumber_clean_Value}"
                            }
                        }
                    }
                }
            }
        },
        "DF_Action": {
            "type": "select",
            "label": "$选取日常本",
            "description": "$刷取目标为合订本",
